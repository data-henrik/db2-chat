# ── IBM Db2 Connection ────────────────────────────────────────────────────────
DB2_DATABASE=your_database_name
DB2_HOSTNAME=localhost
DB2_PORT=50000
DB2_UID=db2user
DB2_PWD=your_password
# DB2_SCHEMA=         # Optional: restrict table listing to this schema

# ── Flask ─────────────────────────────────────────────────────────────────────
# Generate a strong random value: python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=change_me_to_a_random_secret

# ── Ollama ────────────────────────────────────────────────────────────────────
OLLAMA_HOST=http://localhost:11434
DEFAULT_MODEL=llama3.2
